{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "redirects": [
    { "source": "/ADMIN", "destination": "/admin", "permanent": false },
    { "source": "/ADMIN/", "destination": "/admin", "permanent": false },
    { "source": "/PEDIDO", "destination": "/pedido", "permanent": false },
    { "source": "/PEDIDO/", "destination": "/pedido", "permanent": false }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
